{
  "name": "@legant/sdk",
  "version": "0.1.1",
  "description": "Offline verifier + authorizer for Legant delegation tokens (RFC 8693 sub/act), with Tier-B revocation-feed support. Zero runtime dependencies.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/test/*.test.js"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/legant-dev/legant/tree/main/clients/typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/legant-dev/legant.git",
    "directory": "clients/typescript"
  },
  "bugs": {
    "url": "https://github.com/legant-dev/legant/issues"
  },
  "keywords": [
    "legant",
    "delegation",
    "rfc8693",
    "oauth2",
    "ai-agents",
    "mcp",
    "authorization"
  ],
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.10.0"
  }
}
